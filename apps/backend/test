#!/usr/bin/env bash
# Run backend tests inside apps/backend/.venv (creates venv and installs dev deps when needed).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

if [[ ! -d .venv ]]; then
  python3 -m venv .venv
  .venv/bin/pip install -q -r requirements-dev.txt
elif ! .venv/bin/python -c "import allure_pytest" 2>/dev/null; then
  .venv/bin/pip install -q -r requirements-dev.txt
fi

exec .venv/bin/pytest "$@"