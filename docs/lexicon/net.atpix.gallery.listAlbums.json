{
  "lexicon": 1,
  "id": "net.atpix.gallery.listAlbums",
  "defs": {
    "main": {
      "type": "query",
      "description": "List albums for an author, excluding unlisted/permissioned unless caller is authorized.",
      "parameters": {
        "type": "params",
        "required": ["did"],
        "properties": {
          "did": { "type": "string", "format": "did" },
          "visibility": {
            "type": "string",
            "enum": ["public", "unlisted", "permissioned"]
          },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["albums"],
          "properties": {
            "cursor": { "type": "string" },
            "albums": {
              "type": "array",
              "items": { "type": "ref", "ref": "net.atpix.gallery.defs#albumView" }
            }
          }
        }
      }
    }
  }
}