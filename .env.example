# HappyView App View (run separately; default port 3001 avoids Grafana on 3000)
HAPPYVIEW_URL=http://127.0.0.1:3001
VITE_HAPPYVIEW_URL=http://127.0.0.1:3001
# Public URL where the ATPix frontend is served (OAuth client_id origin; no trailing slash)
VITE_DEPLOYMENT_ORIGIN=http://127.0.0.1:5173
# hvc_* client key from HappyView API Clients admin (X-Client-Key on XRPC — not hv_* admin keys)
VITE_HAPPYVIEW_CLIENT_KEY=hvc_your_client_key_here
# Optional: PDS self-service signup URL — shows "Create account" link on sign-in panel (F-017)
# VITE_PDS_SIGNUP_URL=https://pds.atpix.net/account
# Admin API key (hv_*) for lexicon upload and feature flags — create in HappyView dashboard
HAPPYVIEW_ADMIN_KEY=hv_your_admin_key_here
# Same hvc_* key as VITE_HAPPYVIEW_CLIENT_KEY — used by backend BDD OAuth XRPC (BE-4.1)
HAPPYVIEW_CLIENT_KEY=
# Deployment origin for OAuth client_id / space appAccess (match VITE_DEPLOYMENT_ORIGIN)
ATPIX_DEPLOYMENT_ORIGIN=http://127.0.0.1:5173

# Multi-account permissioned-spaces BDD (BE-4.1) — export after OAuth sign-in per README
# TEST_OWNER_DID=did:plc:...
# TEST_OWNER_ACCESS_TOKEN=...
# TEST_OWNER_REFRESH_TOKEN=...
# TEST_OWNER_DPOP_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}
# TEST_OWNER_PDS_URL=https://pds.atpix.net
# TEST_OWNER_ISSUER=https://pds.atpix.net
# TEST_MEMBER_DID=did:plc:...
# TEST_MEMBER_ACCESS_TOKEN=...
# TEST_MEMBER_REFRESH_TOKEN=...
# TEST_MEMBER_DPOP_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}
# TEST_MEMBER_PDS_URL=https://pds.atpix.net
# TEST_MEMBER_ISSUER=https://pds.atpix.net

# ATPix auxiliary API (FastAPI)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_BACKEND_URL=http://127.0.0.1:8000
# C2PA claim-signing PEM material (production requires org-issued certs with c2pa-kp-claimSigning EKU)
# C2PA_SIGNING_CERTS_PATH=apps/backend/tests/fixtures/c2pa/es256_certs.pem
# C2PA_SIGNING_KEY_PATH=apps/backend/tests/fixtures/c2pa/es256_private.key
# C2PA_TSA_URL=http://timestamp.digicert.com
# Allow CAI test fixtures only for local development (never enable in production Docker)
C2PA_ALLOW_DEV_SIGNING=true
# Require OAuth bearer tokens on POST /c2pa/manifest/embed (disable only for local curl testing)
C2PA_REQUIRE_AUTH=false